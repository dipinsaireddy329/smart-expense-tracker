from datetime import date
from sqlalchemy import func

from app import db
from app.models import Expense


# -----------------------------
# Current month helper
# -----------------------------
def current_month_window():
    today = date.today()
    return today.month, today.year


# -----------------------------
# Safe money converter
# -----------------------------
def money(value):
    try:
        return float(value or 0)
    except:
        return 0.0


# -----------------------------
# Monthly total expenses
# -----------------------------
def monthly_total(user_id, month, year):
    total = (
        db.session.query(func.coalesce(func.sum(Expense.amount), 0))
        .filter(
            Expense.user_id == user_id,
            func.extract("month", Expense.expense_date) == month,
            func.extract("year", Expense.expense_date) == year
        )
        .scalar()
    )

    return float(total or 0)


# -----------------------------
# Monthly chart series (FIXED)
# -----------------------------
def monthly_series(user_id, year):
    labels = []
    values = []

    for month in range(1, 13):
        total = (
            db.session.query(func.coalesce(func.sum(Expense.amount), 0))
            .filter(
                Expense.user_id == user_id,
                func.extract("year", Expense.expense_date) == year,
                func.extract("month", Expense.expense_date) == month
            )
            .scalar()
        )

        labels.append(month)
        values.append(float(total or 0))

    return {
        "labels": labels,
        "values": values
    }


# -----------------------------
# Category-wise totals (FIXED)
# -----------------------------
def category_totals(user_id, month, year):
    results = (
        db.session.query(
            Expense.category_id,
            func.coalesce(func.sum(Expense.amount), 0).label("total")
        )
        .filter(
            Expense.user_id == user_id,
            func.extract("month", Expense.expense_date) == month,
            func.extract("year", Expense.expense_date) == year
        )
        .group_by(Expense.category_id)
        .all()
    )

    return [
        {
            "category_id": r.category_id,
            "total": float(r.total or 0)
        }
        for r in results
    ]

